<?xml version="1.0"?>
<launch>
  <!-- SOLiD-only benchmark: subscribe to lidar + pose, publish ~metrics and optional CSV. -->
  <arg name="config_path" default="$(find gmmslam)/config/params.yaml"/>
  <arg name="lidar_topic" default="/m500_1/mpa/lidar_pc"/>
  <arg name="pose_topic" default="/m500_1/mavros/local_position/pose"/>
  <arg name="csv_path" default=""/>
  <arg name="log_hz" default="10"/>
  <arg name="reference_mode" default="first"/>
  <arg name="arc_return_drop_m" default="0.15"/>

  <node pkg="gmmslam" type="solid_descriptor_benchmark" name="solid_descriptor_benchmark"
        output="screen">
    <param name="config_path" value="$(arg config_path)"/>
    <param name="lidar_topic" value="$(arg lidar_topic)"/>
    <param name="pose_topic" value="$(arg pose_topic)"/>
    <param name="log_hz" value="$(arg log_hz)"/>
    <param name="csv_path" value="$(arg csv_path)"/>
    <param name="reference_mode" value="$(arg reference_mode)"/>
    <param name="arc_return_drop_m" value="$(arg arc_return_drop_m)"/>
  </node>
</launch>
